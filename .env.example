# Скопируйте в .env и заполните:  cp .env.example .env
# .env в git НЕ коммитится (см. .gitignore).

# --- changedetection.io ---
# Разрешить слежение за локальными файлами через file:///datastore/watched/<file>
# (см. заметку о безопасности в README — CVE-2024-51998).
ALLOW_FILE_URI=true
# Внешний базовый URL для ссылок в уведомлениях (за reverse-proxy — ваш реальный адрес).
# Порт 5050: на macOS 5000 занят AirPlay Receiver.
BASE_URL=http://localhost:5050
# Параллельные воркеры-фетчеры (поднять для большого списка источников).
FETCH_WORKERS=10

# --- AI-резюме изменений (Anthropic Claude) ---
# Этот же ключ введите в UI: Settings > LLM.
ANTHROPIC_API_KEY=

# --- Email (Apprise) ---
# Сам канал настраивается в UI (Settings > Notifications) как Apprise-URL, например:
#   mailtos://USER:PASS@smtp.example.com?to=team@example.com&from=docmonitor@example.com
# Здесь — только для справки; CDIO хранит конфиг уведомлений в своём datastore.

# --- CDIO API ---
# Берётся из UI: Settings > API. Нужен provisioning-скриптам.
CDIO_API_KEY=

# --- Office adapter ---
# Интервал periodic-прохода адаптера (doc/docx/pdf -> txt), В СЕКУНДАХ. Дефолт 600.
# Реактивный режим (watchdog) ловит правки за ~1с, но на Docker Desktop (Windows/macOS)
# с папкой office-src на хостовом ФС (напр. C:\) события mtime до контейнера могут НЕ
# доезжать — тогда уменьшите интервал, и periodic-проход будет ловить изменения чаще.
OFFICE_INTERVAL=600

# --- Auth-sources (Phase 3) ---
# Конвенция: для каждого id в config/auth-sources.yaml — две переменные
#   AUTH_<UPPER_ID>_USER  /  AUTH_<UPPER_ID>_PASS
# В YAML ссылаемся как ${AUTH_<UPPER_ID>_USER}; provisioning подставляет при
# создании watch'а в CDIO. Подробно: docs/auth-sources.md
# Пример (заполните свои):
# AUTH_AMUSNET_USER=
# AUTH_AMUSNET_PASS=
